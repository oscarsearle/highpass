</a>

<script>
(function () {
  'use strict';

  var DURATION = 10000;
  var slides = [
    {
      name: 'FLOW ONE',
      eyebrow: null,
      tagline: 'A portable electric pump that reaches road pressure on its own. 120 PSI. USB-C rechargeable. Auto-stop at your preset pressure.',
      primaryLabel: 'Shop Flow One',
      primaryHref: '/products/highpass-flow-one',
      secondaryLabel: 'See the line',
      secondaryHref: '{{ routes.all_products_collection_url }}'
    },
    {
      name: 'LOOM V1',
      eyebrow: 'Coming soon',
      tagline: 'A precision LED trail light. Beam shaped to the trail, runtime measured in rides not minutes. Launching soon.',
      primaryLabel: 'Notify me',
      primaryHref: '/products/highpass-loom-v1',
      secondaryLabel: 'See the line',
      secondaryHref: '{{ routes.all_products_collection_url }}'
    }
  ];

  var current = 0;
  var paused = false;
  var timer = null;
  var switching = false;

  var bgs = [document.getElementById('hp-bg-0'), document.getElementById('hp-bg-1')];
  var nameWrap = document.getElementById('hp-name-wrap');
  var eyebrowEl = document.getElementById('hp-eyebrow');
  var headlineEl = document.getElementById('hp-headline');
  var ctasEl = document.getElementById('hp-ctas');
  var ctaPrimary = document.getElementById('hp-cta-primary');
  var ctaSecondary = document.getElementById('hp-cta-secondary');
  var taglineEl = document.getElementById('hp-tagline');
  var tabs = document.querySelectorAll('.hp-hero__tab');
  var panel = document.getElementById('hp-panel');

  function restartFill(tab) {
    var fill = tab.querySelector('.hp-hero__tab-fill');
    fill.style.animation = 'none';
    void fill.offsetWidth;
    fill.style.animation = '';
  }

  function switchTo(next) {
    if (switching || next === current) return;
    switching = true;

    nameWrap.classList.add('fading');
    ctasEl.classList.add('fading');

    setTimeout(function () {
      var slide = slides[next];
      current = next;

      if (slide.eyebrow) {
        eyebrowEl.textContent = slide.eyebrow;
        eyebrowEl.style.display = '';
      } else {
        eyebrowEl.style.display = 'none';
      }
      headlineEl.textContent = slide.name;
      taglineEl.textContent = slide.tagline;
      ctaPrimary.textContent = slide.primaryLabel;
      ctaPrimary.href = slide.primaryHref;
      ctaSecondary.textContent = slide.secondaryLabel;
      ctaSecondary.href = slide.secondaryHref;

      bgs.forEach(function (bg, i) {
        bg.classList.toggle('hp-hero__slide-bg--active', i === next);
      });

      tabs.forEach(function (tab, i) {
        tab.classList.toggle('active', i === next);
        if (i === next) restartFill(tab);
      });

      nameWrap.classList.remove('fading');
      ctasEl.classList.remove('fading');
      switching = false;
    }, 240);
  }

  function startTimer() {
    clearTimeout(timer);
    if (!paused) {
      timer = setTimeout(function () {
        switchTo((current + 1) % slides.length);
        startTimer();
      }, DURATION);
    }
  }

  tabs.forEach(function (tab, i) {
    tab.addEventListener('click', function () {
      clearTimeout(timer);
      switchTo(i);
      if (!paused) startTimer();
    });
  });

  if (panel) {
    panel.addEventListener('mouseenter', function () {
      paused = true;
      clearTimeout(timer);
      tabs.forEach(function (tab) {
        if (tab.classList.contains('active')) {
          tab.querySelector('.hp-hero__tab-fill').style.animationPlayState = 'paused';
        }
      });
    });
    panel.addEventListener('mouseleave', function () {
      paused = false;
      tabs.forEach(function (tab) {
        if (tab.classList.contains('active')) {
          tab.querySelector('.hp-hero__tab-fill').style.animationPlayState = 'running';
        }
      });
      startTimer();
    });
  }

  {%- if section.settings.video_url != blank -%}
  var videoPlay = document.getElementById('hp-video-play');
  var videoEmbed = document.getElementById('hp-video-embed');
  if (videoPlay && videoEmbed) {
    videoPlay.addEventListener('click', function () {
      videoEmbed.src = videoEmbed.dataset.src;
      videoEmbed.style.display = 'block';
      videoPlay.style.display = 'none';
    });
  }
  {%- endif -%}

  var nav = document.querySelector('.hp-nav');
  if (nav) {
    var onScroll = function () { nav.classList.toggle('is-scrolled', window.scrollY > 10); };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  startTimer();
})();
</script>

{% schema %}
{
  "name": "HIGHPASS Home",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "FLOW ONE hero image",
      "info": "Recommended: 2000px wide, dark trail or product shot. Defaults to flow-one-hero.png asset."
    },
    {
      "type": "header",
      "content": "Showcase images"
    },
    {
      "type": "image_picker",
      "id": "showcase_flow_image",
      "label": "FLOW ONE showcase image",
      "info": "4:3 ratio, product on dark background"
    },
    {
      "type": "image_picker",
      "id": "showcase_loom_image",
      "label": "LOOM V1 showcase image",
      "info": "4:3 ratio, product on dark background"
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "YouTube video URL",
      "info": "Paste a YouTube URL. Leave blank to show the placeholder."
    }
  ],
  "presets": [
    {
      "name": "HIGHPASS Home"
    }
  ]
}
{% endschema %}
