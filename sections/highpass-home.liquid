{%- comment -%} HIGHPASS Homepage — Design System v1 {%- endcomment -%}

{%- comment -%} HERO: full-viewport slideshow, FLOW ONE + LOOM V1 {%- endcomment -%}
<section class="hp-hero" id="hp-hero" aria-label="Hero">

  <div class="hp-hero__bgs">
    {%- comment -%} Slide 0: FLOW ONE — full-bleed photo {%- endcomment -%}
    <div id="hp-bg-0" class="hp-hero__slide-bg hp-hero__slide-bg--active">
      {%- if section.settings.hero_image != blank -%}
        <div style="position:absolute;inset:0;background-image:url({{ section.settings.hero_image | image_url: width: 2000 }});background-size:cover;background-position:center 42%;"></div>
      {%- else -%}
        <div style="position:absolute;inset:0;background-image:url({{ 'flow-one-hero.png' | asset_url }});background-size:cover;background-position:center 42%;"></div>
      {%- endif -%}
    </div>

    {%- comment -%} Slide 1: LOOM V1 — dark red atmospheric treatment {%- endcomment -%}
    <div id="hp-bg-1" class="hp-hero__slide-bg">
      <div style="position:absolute;inset:0;background-image:url({{ 'texture-red-atmosphere.png' | asset_url }});background-size:cover;background-position:center;opacity:0.8;"></div>
      <div style="position:absolute;inset:0;background-image:url({{ 'texture-concrete.png' | asset_url }});background-size:cover;mix-blend-mode:overlay;opacity:0.5;"></div>
      <div style="position:absolute;inset:0;background:radial-gradient(120% 90% at 68% 32%, rgba(10,10,10,0) 0%, rgba(10,10,10,0.5) 68%, rgba(10,10,10,0.92) 100%);"></div>
    </div>
  </div>

  {%- comment -%} Legibility scrims: top for the transparent nav, bottom and left for corner type {%- endcomment -%}
  <div class="hp-hero__scrim"></div>
  <div class="hp-grain"></div>

  {%- comment -%} Bottom-left: giant product wordmark (crossfades per slide) {%- endcomment -%}
  <div class="hp-hero__name">
    <div class="hp-hero__name-wrap" id="hp-name-wrap">
      <span class="hp-hero__eyebrow" id="hp-eyebrow" style="display:none;"></span>
      <h1 class="hp-hero__headline" id="hp-headline">FLOW ONE</h1>
    </div>
  </div>

  {%- comment -%} Bottom-right: slide tabs (persistent) + CTAs and tagline (crossfade) {%- endcomment -%}
  <div class="hp-hero__panel" id="hp-panel">

    <div class="hp-hero__tabs">
      <button class="hp-hero__tab active" type="button" data-slide="0">
        <div class="hp-hero__tab-label">
          <span class="hp-hero__tab-num">01</span>
          <span class="hp-hero__tab-name">Flow One</span>
        </div>
        <div class="hp-hero__tab-track">
          <div class="hp-hero__tab-fill"></div>
        </div>
      </button>
      <button class="hp-hero__tab" type="button" data-slide="1">
        <div class="hp-hero__tab-label">
          <span class="hp-hero__tab-num">02</span>
          <span class="hp-hero__tab-name">Loom V1</span>
        </div>
        <div class="hp-hero__tab-track">
          <div class="hp-hero__tab-fill"></div>
        </div>
      </button>
    </div>

    <div class="hp-hero__ctas" id="hp-ctas">
      <div class="hp-hero__cta-row">
        <a href="/products/highpass-flow-one" class="hp-btn hp-btn--primary hp-btn--sm" id="hp-cta-primary">Shop Flow One</a>
        <a href="{{ routes.all_products_collection_url }}" class="hp-btn hp-btn--secondary hp-btn--sm" id="hp-cta-secondary">See the line</a>
      </div>
      <p class="hp-hero__tagline" id="hp-tagline">A portable electric pump that reaches road pressure on its own. 120 PSI. USB-C rechargeable. Auto-stop at your preset pressure.</p>
    </div>

  </div>
</section>

{%- comment -%} SPECS STRIP {%- endcomment -%}
<div class="hp-strip" role="list" aria-label="Key specifications">
  <div class="hp-strip__inner">
    <div class="hp-strip__cell" role="listitem">
      <span class="hp-strip__figure">120 PSI</span>
      <span class="hp-strip__label">Brushless motor</span>
    </div>
    <div class="hp-strip__cell" role="listitem">
      <span class="hp-strip__figure">&lt; 90 sec</span>
      <span class="hp-strip__label">Any tyre, inflated</span>
    </div>
    <div class="hp-strip__cell" role="listitem">
      <span class="hp-strip__figure">Auto-stop</span>
      <span class="hp-strip__label">At your preset pressure</span>
    </div>
    <div class="hp-strip__cell" role="listitem">
      <span class="hp-strip__figure">USB-C</span>
      <span class="hp-strip__label">Recharge anywhere</span>
    </div>
  </div>
</div>

{%- comment -%} SHOWCASE: THE LINE {%- endcomment -%}
<section class="hp-showcase" id="hp-showcase" aria-label="The line">
  <div class="hp-showcase__inner">

    <div class="hp-showcase__header">
      <h2 class="hp-showcase__title">The line</h2>
      <span class="hp-showcase__meta">2 products · more in the works</span>
    </div>

    <div class="hp-showcase__rows">

      {%- comment -%} FLOW ONE — image left {%- endcomment -%}
      <div class="hp-showcase__row">
        <div class="hp-showcase__media">
          {%- if section.settings.showcase_flow_image != blank -%}
            <img
              class="hp-showcase__img"
              src="{{ section.settings.showcase_flow_image | image_url: width: 1200 }}"
              srcset="{{ section.settings.showcase_flow_image | image_url: width: 600 }} 600w, {{ section.settings.showcase_flow_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 900px) 100vw, 55vw"
              alt="HIGHPASS FLOW ONE"
              loading="lazy"
            >
          {%- else -%}
            <div class="hp-showcase__placeholder">
              <svg width="48" height="48" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1" fill="none" aria-hidden="true">
                <rect x="4" y="10" width="40" height="28" rx="2"/>
                <circle cx="17" cy="22" r="4"/>
                <polyline points="4,38 16,26 24,34 32,24 44,38"/>
              </svg>
              <span class="hp-showcase__placeholder-text">Flow One product image</span>
            </div>
          {%- endif -%}
        </div>
        <div class="hp-showcase__copy">
          <span class="hp-showcase__kicker">The pump. Nothing else.</span>
          <h2 class="hp-showcase__name">FLOW ONE</h2>
          <p class="hp-showcase__desc">A portable electric pump that reaches road pressure on its own. 120 PSI brushless motor, USB-C rechargeable, auto-stop at your preset pressure. Any tyre, inflated in under 90 seconds.</p>
          <ul class="hp-showcase__details">
            <li class="hp-showcase__detail">
              <span class="hp-showcase__detail-num">01</span>
              <span>Auto-stop at your set target pressure. Set it once, walk away.</span>
            </li>
            <li class="hp-showcase__detail">
              <span class="hp-showcase__detail-num">02</span>
              <span>CNC alloy body, anodised matte black.</span>
            </li>
            <li class="hp-showcase__detail">
              <span class="hp-showcase__detail-num">03</span>
              <span>Charge it Sunday. Don't think about it until next Sunday.</span>
            </li>
          </ul>
          <div class="hp-showcase__actions">
            <a href="/products/highpass-flow-one" class="hp-btn hp-btn--primary">Shop Flow One</a>
            <span class="hp-showcase__price">$99.99 NZD</span>
          </div>
        </div>
      </div>

      {%- comment -%} LOOM V1 — image right (flipped row) {%- endcomment -%}
      <div class="hp-showcase__row hp-showcase__row--flip">
        <div class="hp-showcase__media hp-showcase__media--dim">
          <span class="hp-showcase__coming-tag">Coming soon</span>
          {%- if section.settings.showcase_loom_image != blank -%}
            <img
              class="hp-showcase__img"
              src="{{ section.settings.showcase_loom_image | image_url: width: 1200 }}"
              alt="HIGHPASS LOOM V1"
              loading="lazy"
            >
          {%- else -%}
            <div class="hp-showcase__placeholder">
              <svg width="48" height="48" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.2" fill="none" aria-hidden="true">
                <circle cx="24" cy="22" r="9"/>
                <line x1="24" y1="4" x2="24" y2="10"/>
                <line x1="24" y1="34" x2="24" y2="40"/>
                <line x1="6" y1="22" x2="12" y2="22"/>
                <line x1="36" y1="22" x2="42" y2="22"/>
                <line x1="11" y1="9" x2="15" y2="13"/>
                <line x1="33" y1="31" x2="37" y2="35"/>
                <line x1="37" y1="9" x2="33" y2="13"/>
                <line x1="15" y1="31" x2="11" y2="35"/>
              </svg>
              <span class="hp-showcase__placeholder-text">Loom V1 product image</span>
            </div>
          {%- endif -%}
        </div>
        <div class="hp-showcase__copy">
          <span class="hp-showcase__kicker">The trail light. Coming soon.</span>
          <h2 class="hp-showcase__name">LOOM V1</h2>
          <p class="hp-showcase__desc">LOOM V1 is a precision LED trail light for mountain and gravel riders. Beam shaped to the trail, runtime measured in rides not minutes. Built for the same trails as the FLOW ONE.</p>
          <ul class="hp-showcase__details">
            <li class="hp-showcase__detail">
              <span class="hp-showcase__detail-num">01</span>
              <span>Beam shaped to the trail, not into eyes.</span>
            </li>
            <li class="hp-showcase__detail">
              <span class="hp-showcase__detail-num">02</span>
              <span>Machined alloy heatsink body.</span>
            </li>
            <li class="hp-showcase__detail">
              <span class="hp-showcase__detail-num">03</span>
              <span>Built for mountain and gravel. Specs confirmed closer to launch.</span>
            </li>
          </ul>
          <div class="hp-showcase__actions">
            <a href="/products/highpass-loom-v1" class="hp-btn hp-btn--secondary">Notify me</a>
            <span style="font-family:var(--font-body);font-weight:500;font-size:11px;letter-spacing:var(--track-label-sm);text-transform:uppercase;color:var(--asphalt);">Launching soon</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

{%- comment -%} VIDEO {%- endcomment -%}
<section class="hp-video" aria-label="Product video">
  <div class="hp-video__inner">
    <div class="hp-video__header">
      <h2 class="hp-video__title">In under ninety seconds</h2>
      <span class="hp-video__meta">film · 0:90</span>
    </div>
    <div class="hp-video__frame">
      <div class="hp-video__hatch"></div>
      {%- if section.settings.video_url != blank -%}
        <div class="hp-video__play" id="hp-video-play">
          <div class="hp-video__play-btn">
            <svg class="hp-video__play-icon" viewBox="0 0 26 30" aria-hidden="true"><path d="M0 0 L26 15 L0 30 Z"/></svg>
          </div>
          <span class="hp-video__play-label">FLOW ONE IN ACTION</span>
        </div>
        <iframe
          class="hp-video__embed"
          id="hp-video-embed"
          src=""
          data-src="{{ section.settings.video_url | replace: 'watch?v=', 'embed/' | replace: 'youtu.be/', 'www.youtube.com/embed/' }}?autoplay=1&rel=0"
          allow="autoplay; fullscreen"
          allowfullscreen
          title="HIGHPASS FLOW ONE in action"
        ></iframe>
      {%- else -%}
        <div class="hp-video__play">
          <div class="hp-video__play-btn" aria-hidden="true">
            <svg class="hp-video__play-icon" viewBox="0 0 26 30" aria-hidden="true"><path d="M0 0 L26 15 L0 30 Z"/></svg>
          </div>
          <span class="hp-video__play-label">[ Product film — drop 16:9 footage ]</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{%- comment -%} BRAND STORY {%- endcomment -%}
<section class="hp-story" aria-label="Brand story">
  <div class="hp-story__texture"></div>
  <div class="hp-grain"></div>
  <div class="hp-story__inner">
    <h2 class="hp-story__headline">Built in Wanaka. <span>One thing at a time.</span></h2>
    <div class="hp-story__body">
      <p class="hp-story__text">HIGHPASS builds precision tools for riders. We start with one product and resolve it fully before we move to the next.</p>
      <p class="hp-story__text">The FLOW ONE is first. LOOM V1 follows. Each one earns its place on the bike. No noise, no filler, no rush.</p>
      <span class="hp-story__location">Wanaka · Aotearoa New Zealand</span>
    </div>
  </div>
</section>

